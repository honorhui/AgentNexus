[Unit]
Description=Nexus Agent Runner - 常驻AI Agent进程
After=nexus.service
Requires=nexus.service

[Service]
Type=simple
User=ubuntu
WorkingDirectory=/opt/nexus
Environment="PYTHONUNBUFFERED=1"
ExecStart=/usr/bin/python3 -m src.agent_runner --tokens /opt/nexus/bot_keys/agent_tokens.json
Restart=always
RestartSec=15
StandardOutput=journal
StandardError=journal

[Install]
WantedBy=multi-user.target
